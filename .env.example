# Copy this file to .env and fill in the values.
# Generate SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=CHANGE_ME_generate_a_real_key

# Set to "production" in production; "development" enables debug mode and reloader
FLASK_ENV=production

# Set to True if running behind HTTPS (enables Secure cookie flag)
SESSION_COOKIE_SECURE=True

# Required for `flask create-admin` inside the container
FLASK_APP=app.py

# Number of trusted reverse proxies in front of this app.
# With the default docker-compose setup (nginx sidecar) this must be 1.
# Over-trusting this value allows clients to spoof their IP address.
PROXY_COUNT=1
